# Copy this to .env and fill in real values.
# Generate a SECRET_KEY: python3 -c "import secrets; print(secrets.token_urlsafe(50))"

SECRET_KEY=CHANGE_ME_PLEASE_GENERATE_50_CHAR_RANDOM
DB_PASSWORD=CHANGE_ME_PLEASE

# Optional — auto-create a superuser on first boot
CREATE_SUPERUSER_EMAIL=admin@example.com
CREATE_SUPERUSER_PASSWORD=CHANGE_ME_PLEASE

# Optional — pin BugSink version
# BUGSINK_VERSION=2.1.2

# Optional — if exposing publicly
# BASE_URL=https://bugsink.example.com
# ALLOWED_HOSTS=bugsink.example.com,localhost
